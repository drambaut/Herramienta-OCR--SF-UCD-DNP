AZURE_FORM_RECOGNIZER_ENDPOINT=https://<nombre-del-recurso>.cognitiveservices.azure.com/    # Endpoint de Document Intelligence (desde Azure Portal)
AZURE_FORM_RECOGNIZER_KEY=tu_api_key_de_document_intelligence                               # Key1 o Key2 del recurso
AZURE_OPENAI_ENDPOINT=https://<nombre-del-recurso>.openai.azure.com/                        # Endpoint de Azure OpenAI
AZURE_OPENAI_API_KEY=tu_api_key_de_azure_openai                                             # API Key desde "Keys and Endpoint"
AZURE_OPENAI_API_VERSION=2024-02-15-preview                                                 # Versión de la API (ejemplo recomendado)
AZURE_OPENAI_ASSISTANT_ID=asst_id_del_assistant                                             # ID del Assistant (solo si usas Assistants API)
AZURE_OPENAI_DEPLOYMENT_NAME=nombre_deployment_modelo                                       # Nombre del deployment (ej: gpt-4o, definido por ti en Azure)